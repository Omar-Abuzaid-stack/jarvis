<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jarvis.mobile-gateway</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/user/Desktop/jarvis/venv/bin/python3</string>
    <string>/Users/user/Desktop/jarvis/mobile_gateway.py</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/user/Desktop/jarvis</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/Users/user</string>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>PYTHONPATH</key>
    <string>/Users/user/Desktop/jarvis:/Users/user/OpenJarvis/src</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/mobile-gateway.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/mobile-gateway.err.log</string>
  <key>ProcessType</key>
  <string>Standard</string>
</dict>
</plist>
