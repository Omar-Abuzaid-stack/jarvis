# ============================================================
# JARVIS — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── Required: Mistral AI (replaces Anthropic) ──
MISTRAL_API_KEY=awKEm1o4t9xGNiGwpHp7BSzSrKYjDb4L
JARVIS_CHAT_MODEL=mistral-large-latest
JARVIS_CODE_MODEL=codestral-latest
# Optional same-family fallbacks only. Leave blank to avoid cross-model drift.
# JARVIS_CHAT_FALLBACK_MODEL=
# JARVIS_CODE_FALLBACK_MODEL=

# ── Optional: Your name (JARVIS addresses you as "sir" by default) ──
# USER_NAME=Omar

# ── Optional: Apple Calendar accounts (comma-separated emails) ──
# If not set, JARVIS reads ALL calendars from Apple Calendar
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com

# ── Voice — Microsoft Edge TTS (auto-configured, no key needed) ──
# Primary: en-GB-RyanNeural  Pitch: -25Hz  Volume: +25%
# Fallback: macOS Daniel (works offline, no internet required)
# EDGE_TTS_VOICE=en-GB-RyanNeural
